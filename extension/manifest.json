{
  "manifest_version": 3,
  "name": "Vibesfolio",
  "version": "1.0.0",
  "description": "Save prompts and resources to your Vibesfolio library",
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://vibesfolio.lovable.app/*", "https://vibesfolio.volynska.dev/*"],
      "js": ["src/content/content-script.ts"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["activeTab", "contextMenus", "storage", "identity", "scripting", "tabs"],
  "oauth2": {
    "client_id": "205235879731-prs46ardcon5tdj84em0439l4vvm2oa1.apps.googleusercontent.com",
    "scopes": ["openid", "email", "profile"]
  },
  "host_permissions": ["<all_urls>"]
}
